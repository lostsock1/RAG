{
  "realm": "uber-rag",
  "enabled": true,
  "displayName": "Uber-RAG Local",
  "registrationAllowed": false,
  "rememberMe": false,
  "resetPasswordAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "defaultRoles": [
    "offline_access",
    "uma_authorization"
  ],
  "roles": {
    "realm": [
      {
        "name": "editor",
        "description": "Can upload and manage accessible documents"
      },
      {
        "name": "admin",
        "description": "Can manage ACLs across tenant documents"
      }
    ]
  },
  "groups": [
    {
      "name": "alpha"
    },
    {
      "name": "beta"
    }
  ],
  "clientScopes": [
    {
      "name": "uber-rag-api-scopes",
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "tenant-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenant_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "subject-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "sub",
            "jsonType.label": "String"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups",
            "jsonType.label": "String"
          }
        },
        {
          "name": "permissions",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "permissions",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "claim.name": "permissions",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "uber-rag-api",
      "name": "Uber-RAG API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "uber-rag-api-scopes"
      ],
      "optionalClientScopes": [
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "uber-rag-api",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Alpha",
      "attributes": {
        "tenant_id": [
          "00000000-0000-0000-0000-000000000001"
        ],
        "permissions": [
          "documents:read documents:write"
        ]
      },
      "groups": [
        "/alpha"
      ],
      "realmRoles": [
        "editor"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "alicepass",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Beta",
      "attributes": {
        "tenant_id": [
          "00000000-0000-0000-0000-000000000001"
        ],
        "permissions": [
          "documents:read documents:write"
        ]
      },
      "groups": [
        "/beta"
      ],
      "realmRoles": [
        "editor"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "bobpass",
          "temporary": false
        }
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@example.com",
      "firstName": "Admin",
      "lastName": "User",
      "attributes": {
        "tenant_id": [
          "00000000-0000-0000-0000-000000000001"
        ],
        "permissions": [
          "documents:read documents:write"
        ]
      },
      "realmRoles": [
        "admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "adminpass",
          "temporary": false
        }
      ]
    }
  ]
}
