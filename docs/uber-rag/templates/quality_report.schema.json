{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UberRAGIngestionQualityReport",
  "type": "object",
  "required": [
    "document_id",
    "source_hash",
    "parser",
    "pages_expected",
    "pages_parsed",
    "chunks_created",
    "index_status",
    "warnings"
  ],
  "properties": {
    "document_id": {
      "type": "string"
    },
    "source_hash": {
      "type": "string"
    },
    "parser": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "options": {
          "type": "object"
        }
      }
    },
    "pages_expected": {
      "type": "integer",
      "minimum": 0
    },
    "pages_parsed": {
      "type": "integer",
      "minimum": 0
    },
    "ocr_pages": {
      "type": "integer",
      "minimum": 0
    },
    "ocr_confidence_avg": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "toc_detected": {
      "type": "boolean"
    },
    "tables_detected": {
      "type": "integer",
      "minimum": 0
    },
    "formulas_detected": {
      "type": "integer",
      "minimum": 0
    },
    "figures_detected": {
      "type": "integer",
      "minimum": 0
    },
    "chunks_created": {
      "type": "integer",
      "minimum": 0
    },
    "embedding_model": {
      "type": "string"
    },
    "embedding_status": {
      "type": "string"
    },
    "lexical_index_status": {
      "type": "string"
    },
    "vector_index_status": {
      "type": "string"
    },
    "index_status": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_pages": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    }
  }
}
